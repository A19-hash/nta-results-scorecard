<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEET (UG) 2026 Score Card</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <header class="top-header compact">
        NATIONAL ELIGIBILITY CUM ENTRANCE TEST (UG) - 2026
    </header>

    <main class="result-shell">

        <section class="result-card">

            <p class="eyebrow">
                Candidate Result Portal
            </p>

            <h1>Score Card</h1>

            <table class="result-table">
                <tr>
                    <td><strong>Candidate Name</strong></td>
                    <td>
                        <%= student.student_name %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Application Number</strong></td>
                    <td>
                        <%= student.application_no %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Father / Guardian</strong></td>
                    <td>
                        <%= student.father_name || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Mother / Guardian</strong></td>
                    <td>
                        <%= student.mother_name || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Date of Birth</strong></td>
                    <td>
                        <%= student.date_of_birth || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Gender</strong></td>
                    <td>
                        <%= student.gender || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Nationality</strong></td>
                    <td>
                        <%= student.nationality || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Category</strong></td>
                    <td>
                        <%= student.category || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Address</strong></td>
                    <td>
                        <%= student.address || "-" %>
                    </td>
                </tr>
                <tr>
                    <td><strong>Examination</strong></td>
                    <td>NEET (UG) - 2026</td>
                </tr>
                <tr>
                    <td><strong>Status</strong></td>
                    <td>
                        <%= student.result_pdf ? "Result Available" : "Result Pending" %>
                    </td>
                </tr>
            </table>

            <% if (student.result_pdf) { %>
                <div class="button-row">
                    <a class="download-button" href="<%= student.result_pdf %>" target="_blank" rel="noreferrer">
                        View Result PDF
                    </a>
                    <a class="secondary-button" href="/print-result" target="_blank">
                        Print Result PDF
                    </a>
                </div>
                <% } else { %>
                    <p class="notice">
                        Result has not been uploaded yet.
                    </p>
                    <% } %>

                        <form action="/logout" method="POST">
                            <button class="danger-button" type="submit">
                                Logout
                            </button>
                        </form>

        </section>

    </main>

</body>

</html>