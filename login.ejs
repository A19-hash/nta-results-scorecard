<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEET (UG) 2026 Login - Result Portal</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .login-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            justify-content: center;
            padding: 20px;
        }

        .top-header {
            width: 100%;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
        }

        .main-box {
            margin-top: 80px;
        }

        form {
            padding: 35px 40px;
        }

        label {
            font-weight: 600;
            display: block;
            color: #333;
            margin-bottom: 8px;
            font-size: 14px;
        }

        input[type="text"],
        input[type="password"] {
            box-sizing: border-box;
            width: 100%;
            padding: 12px 14px;
            margin-bottom: 20px;
            border: 1px solid #d0d7e8;
            border-radius: 6px;
            font-size: 15px;
            transition: border-color 0.3s ease;
        }

        input[type="text"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: #003366;
            box-shadow: 0 0 0 3px rgba(0, 51, 102, 0.1);
        }

        .captcha-img {
            width: 100%;
            max-width: 250px;
            height: auto;
            margin: 0 auto 20px;
            border: 1px solid #d0d7e8;
            border-radius: 6px;
            display: block;
            background: #f9f9f9;
        }

        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #003366 0%, #004d99 100%);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 51, 102, 0.3);
        }

        button:active {
            transform: translateY(0);
        }

        .error {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px 14px;
            border-radius: 6px;
            margin-bottom: 20px;
            border-left: 4px solid #dc2626;
            font-size: 14px;
        }
    </style>
</head>

<body>

    <div class="top-header">
        NATIONAL ELIGIBILITY CUM ENTRANCE TEST (UG) - 2026
    </div>

    <div class="login-container">
        <div class="main-box">

            <div class="blue-bar">
                Login Through Application Number & Password
            </div>

            <form action="/login" method="POST">
                <% if (error) { %>
                    <p class="error">
                        <%= error %>
                    </p>
                    <% } %>

                        <label for="application_no">Application Number</label>

                        <input id="application_no" type="text" name="application_no" required>

                        <label for="password">Password</label>

                        <input id="password" type="password" name="password" required>

                        <label for="captcha">Security Pin</label>

                        <input id="captcha" type="text" name="captcha" required>

                        <img src="/captcha" class="captcha-img" alt="Security pin">

                        <button type="submit">
                            Submit
                        </button>

            </form>

        </div>

</body>

</html>