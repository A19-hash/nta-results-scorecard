<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="top-header compact">
        NATIONAL ELIGIBILITY CUM ENTRANCE TEST (UG) - 2026
    </div>

    <div class="admin-shell">

        <div class="toolbar">
            <div>
                <h1>Admin Dashboard</h1>
                <p>Manage students, results, PDFs and login records.</p>
            </div>

            <a href="/admin/students" class="download-button small">
                Manage Students
            </a>
        </div>

        <div class="result-card">

            <p class="eyebrow">
                Administration Panel
            </p>

            <h2>Welcome Administrator</h2>

            <p>
                Use this dashboard to:
            </p>

            <ul>
                <li>Add new students</li>
                <li>Edit student information</li>
                <li>Delete records</li>
                <li>Upload result PDFs</li>
                <li>Manage login credentials</li>
                <li>Generate result links</li>
            </ul>

            <a href="/admin/students" class="download-button">
                Open Student Management
            </a>

        </div>

    </div>

</body>

</html>