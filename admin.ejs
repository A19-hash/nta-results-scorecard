<!DOCTYPE html>
<html lang="en">

<head>
    <title>Admin | NEET Result Portal</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="top-header compact">
        NEET Result Portal Admin
    </header>

    <main class="admin-shell">
        <section class="toolbar">
            <div>
                <h1>Student Records</h1>
                <p>
                    Saving records to MongoDB - paste hosted result links or upload PDFs
                </p>
            </div>
            <form action="/admin/logout" method="POST" class="inline-form">
                <button class="secondary-button" type="submit">Logout</button>
            </form>
        </section>

        <% if (message) { %>
            <p class="notice">
                <%= message %>
            </p>
            <% } %>

                <section class="split-layout">
                    <form class="panel-form"
                        action="<%= editStudent ? `/admin/students/${editStudent._id}` : '/admin/students' %>"
                        method="POST" enctype="multipart/form-data">
                        <h2>
                            <%= editStudent ? "Edit Student" : "Add Student" %>
                        </h2>

                        <label for="father_name">Father / Guardian Name</label>
                        <input id="father_name" type="text" name="father_name"
                            value="<%= editStudent?.father_name || '' %>">

                        <label for="mother_name">Mother / Guardian Name</label>
                        <input id="mother_name" type="text" name="mother_name"
                            value="<%= editStudent?.mother_name || '' %>">

                        <label for="date_of_birth">Date of Birth</label>
                        <input id="date_of_birth" type="date" name="date_of_birth"
                            value="<%= editStudent?.date_of_birth || '' %>">

                        <label for="gender">Gender</label>
                        <input id="gender" type="text" name="gender" value="<%= editStudent?.gender || '' %>">

                        <label for="nationality">Nationality</label>
                        <input id="nationality" type="text" name="nationality"
                            value="<%= editStudent?.nationality || '' %>">

                        <label for="address">Address</label>
                        <input id="address" type="text" name="address" value="<%= editStudent?.address || '' %>">

                        <label for="category">Category</label>
                        <input id="category" type="text" name="category" value="<%= editStudent?.category || '' %>">



                        <label for="application_no">Application Number</label>
                        <input id="application_no" name="application_no"
                            value="<%= editStudent?.application_no || '' %>" required>

                        <label for="student_name">Student Name</label>
                        <input id="student_name" name="student_name" value="<%= editStudent?.student_name || '' %>"
                            required>

                        <label for="password">Password</label>
                        <input id="password" name="password" value="<%= editStudent?.password || '' %>"
                            placeholder="Defaults to application number">

                        <label for="result_file">Upload Result PDF</label>
                        <input id="result_file" type="file" name="result_file" accept="application/pdf">

                        <p class="field-help">
                            Upload the student result PDF file here. Uploaded files are stored in
                            <code>public/uploads</code>.
                        </p>

                        <div class="button-row">
                            <button type="submit">
                                <%= editStudent ? "Save Changes" : "Add Student" %>
                            </button>
                            <% if (editStudent) { %>
                                <a class="secondary-button" href="/admin/students">Cancel</a>
                                <% } %>
                        </div>
                    </form>

                    <section class="table-panel">
                        <% if (students.length===0) { %>
                            <div class="empty-state">
                                <h2>No students yet</h2>
                                <p>Add a student record to enable portal login.</p>
                            </div>
                            <% } else { %>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Application</th>
                                            <th>Name</th>
                                            <th>Category</th>
                                            <th>Result</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% students.forEach((student)=> { %>
                                            <tr>
                                                <td>
                                                    <%= student.application_no %>
                                                </td>
                                                <td>
                                                    <%= student.student_name %>
                                                </td>
                                                <td>
                                                    <%= student.category || "-" %>
                                                </td>
                                                <td>
                                                    <% if (student.result_pdf) { %>
                                                        <a href="<%= student.result_pdf %>" target="_blank"
                                                            rel="noreferrer">Open</a>
                                                        <% } else { %>
                                                            -
                                                            <% } %>
                                                </td>
                                                <td class="actions">
                                                    <% if (student.result_pdf) { %>
                                                        <a class="secondary-button small"
                                                            href="/admin/students/<%= student._id %>/print"
                                                            target="_blank">Print</a>
                                                        <% } %>
                                                            <a class="secondary-button small"
                                                                href="/admin/students/<%= student._id %>/edit">Edit</a>
                                                            <form action="/admin/students/<%= student._id %>/delete"
                                                                method="POST">
                                                                <button class="danger-button small"
                                                                    type="submit">Delete</button>
                                                            </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                                <% } %>
                    </section>
                </section>
    </main>
</body>

</html>