PORT=3000
SESSION_SECRET=replace-this-with-a-long-random-secret
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Cloudinary upload support.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Set this to true for local demos without MongoDB.
SKIP_DB=true

# Optional: only add this if you want MongoDB storage instead of data/students.json.
# MONGODB_URI=mongodb://127.0.0.1:27017/neetclone
